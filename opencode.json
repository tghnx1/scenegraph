{
  "$schema": "https://opencode.ai/config.json",
  "model": "{env:OPENCODE_MODEL}",
  "instructions": [
    "AGENTS.md",
    ".opencode/skills/scenegraph/SKILL.md"
  ],
  "watcher": {
    "ignore": [
      ".git/**",
      ".idea/**",
      ".vscode/**",
      "**/__pycache__/**",
      "**/*.pyc",
      "**/*.log",
      "backend/.venv/**",
      "backend/venv/**",
      "frontend/node_modules/**",
      "node_modules/**",
      "backend/data/import_runs/**",
      "backend/data/*.json",
      "backend/data/*.txt",
      "parsers/data/**",
      "dist/**",
      "build/**",
      "coverage/**"
    ]
  }
}
