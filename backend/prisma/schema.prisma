generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Artist {
  id                   BigInt                 @id @default(autoincrement())
  raArtistId           String?                @unique @map("ra_artist_id")
  name                 String
  contentUrl           String?                @map("content_url")
  urlSafeName          String?                @map("url_safe_name")
  biography            String?
  biographyNormalized   String?                @map("biography_normalized")
  biographyUrl         String?                @map("biography_url")
  biographyStatus      String?                @map("biography_status")
  eventArtists         EventArtist[]
  artistClaims         ArtistClaim[]          @relation("artist_claim_artist")
  manualKnownArtists     ArtistManualConnection[] @relation("manual_known_source")
  manuallyKnownByArtists ArtistManualConnection[] @relation("manual_known_connected")
  extractedTags        ArtistExtractedTag[]
  tagExtractionRuns    ArtistTagExtractionRun[]
  recommendationJobs   RecommendationJob[]

  @@map("artists")
}

model ArtistManualConnection {
  sourceArtistId    BigInt   @map("source_artist_id")
  connectedArtistId BigInt   @map("connected_artist_id")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  sourceArtist      Artist   @relation("manual_known_source", fields: [sourceArtistId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  connectedArtist   Artist   @relation("manual_known_connected", fields: [connectedArtistId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([sourceArtistId, connectedArtistId])
  @@index([connectedArtistId])
  @@map("artist_manual_connections")
}

model Event {
  id                  BigInt                @id @default(autoincrement())
  raEventId           String                @unique @map("ra_event_id")
  title               String
  descriptionText     String?               @map("description_text")
  lineupRaw           String?               @map("lineup_raw")
  lineupResidualText  String?               @map("lineup_residual_text")
  contentUrl          String?               @map("content_url")
  eventDate           DateTime?             @map("event_date") @db.Timestamptz(6)
  startTime           DateTime?             @map("start_time") @db.Timestamptz(6)
  endTime             DateTime?             @map("end_time") @db.Timestamptz(6)
  minimumAge          Int?                  @map("minimum_age")
  costText            String?               @map("cost_text")
  interestedCount     Int?                  @map("interested_count")
  isTicketed          Boolean?              @map("is_ticketed")
  isFestival          Boolean?              @map("is_festival")
  live                Boolean?
  hasSecretVenue      Boolean?              @map("has_secret_venue")
  datePosted          DateTime?             @map("date_posted") @db.Timestamptz(6)
  dateUpdated         DateTime?             @map("date_updated") @db.Timestamptz(6)
  venueId             BigInt?               @map("venue_id")
  venue               Venue?                @relation(fields: [venueId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  eventArtists        EventArtist[]
  eventGenres         EventGenre[]
  eventImages         EventImage[]
  eventPromoters      EventPromoter[]
  eventSourcePayloads EventSourcePayload[]
  extractedTags       EventExtractedTag[]
  tagExtractionRuns   EventTagExtractionRun[]

  @@map("events")
}

model Venue {
  id          BigInt   @id @default(autoincrement())
  raVenueId   String   @unique @map("ra_venue_id")
  name        String
  contentUrl  String?  @map("content_url")
  address     String?
  latitude    Decimal? @db.Decimal(65, 30)
  longitude   Decimal? @db.Decimal(65, 30)
  live        Boolean?
  areaName    String?  @map("area_name")
  countryCode String?  @map("country_code")
  events      Event[]

  @@map("venues")
}

model Genre {
  id          BigInt       @id @default(autoincrement())
  raGenreId   String       @unique @map("ra_genre_id")
  name        String
  slug        String?
  eventGenres EventGenre[]

  @@map("genres")
}

model Promoter {
  id              BigInt           @id @default(autoincrement())
  raPromoterId    String           @unique @map("ra_promoter_id")
  name            String
  contentUrl      String?          @map("content_url")
  live            Boolean?
  hasTicketAccess Boolean?         @map("has_ticket_access")
  eventPromoters  EventPromoter[]

  @@map("promoters")
}

model EventArtist {
  eventId  BigInt @map("event_id")
  artistId BigInt @map("artist_id")
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  artist   Artist @relation(fields: [artistId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@id([eventId, artistId])
  @@map("event_artists")
}

model EventGenre {
  eventId BigInt @map("event_id")
  genreId BigInt @map("genre_id")
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  genre   Genre  @relation(fields: [genreId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@id([eventId, genreId])
  @@map("event_genres")
}

model EventImage {
  id        BigInt  @id @default(autoincrement())
  raImageId String? @unique @map("ra_image_id")
  eventId   BigInt  @map("event_id")
  imageUrl  String  @map("image_url")
  imageType String? @map("image_type")
  altText   String? @map("alt_text")
  event     Event   @relation(fields: [eventId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("event_images")
}

model EventPromoter {
  eventId    BigInt   @map("event_id")
  promoterId BigInt   @map("promoter_id")
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  promoter   Promoter @relation(fields: [promoterId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@id([eventId, promoterId])
  @@map("event_promoters")
}

model EventSourcePayload {
  id            BigInt   @id @default(autoincrement())
  eventId       BigInt   @unique @map("event_id")
  sourceName    String   @default("ra") @map("source_name")
  sourceEventId String   @map("source_event_id")
  payload       Json
  fetchedAt     DateTime @default(now()) @map("fetched_at") @db.Timestamptz(6)
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("event_source_payloads")
}

model EntityEmbedding {
  id          BigInt   @id @default(autoincrement())
  entityType  String   @map("entity_type")
  entityId    BigInt   @map("entity_id")
  model       String
  dimensions  Int
  textHash    String   @map("text_hash")
  textProfile String   @map("text_profile")
  embedding   Float[]
  embeddingVec Unsupported("vector")? @map("embedding_vec")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([entityType, entityId, model, dimensions])
  @@index([entityType, model, dimensions])
  @@map("entity_embeddings")
}

model ArtistExtractedTag {
  id         BigInt   @id @default(autoincrement())
  artistId   BigInt   @map("artist_id")
  tagType    String   @map("tag_type")
  tagValue   String   @map("tag_value")
  source     String   @default("biography")
  confidence Float    @default(0)
  extractor  String
  evidence   String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  artist     Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([artistId, tagType])
  @@map("artist_extracted_tags")
}

model ArtistTagExtractionRun {
  id        BigInt   @id @default(autoincrement())
  artistId  BigInt   @map("artist_id")
  source    String   @default("biography")
  extractor String
  textHash  String   @map("text_hash")
  tagCount  Int      @default(0) @map("tag_count")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  artist    Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("artist_tag_extraction_runs")
}

model EventExtractedTag {
  id         BigInt   @id @default(autoincrement())
  eventId    BigInt   @map("event_id")
  tagType    String   @map("tag_type")
  tagValue   String   @map("tag_value")
  source     String   @default("description")
  confidence Float    @default(0)
  extractor  String
  evidence   String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([eventId, tagType])
  @@map("event_extracted_tags")
}

model EventTagExtractionRun {
  id        BigInt   @id @default(autoincrement())
  eventId   BigInt   @map("event_id")
  source    String   @default("description")
  extractor String
  textHash  String   @map("text_hash")
  tagCount  Int      @default(0) @map("tag_count")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("event_tag_extraction_runs")
}

model RecommendationFeedback {
  id                  BigInt   @id @default(autoincrement())
  userId              BigInt   @map("user_id")
  sourceEntityType    String   @map("source_entity_type")
  sourceEntityId      BigInt   @map("source_entity_id")
  candidateEntityType String   @map("candidate_entity_type")
  candidateEntityId   BigInt   @map("candidate_entity_id")
  feedback            String
  reason              String?
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([userId, sourceEntityType, sourceEntityId, candidateEntityType, candidateEntityId])
  @@index([userId])
  @@index([userId, sourceEntityType, sourceEntityId])
  @@index([userId, candidateEntityType, candidateEntityId])
  @@map("recommendation_feedback")
}

model ArtistClaim {
  id             BigInt    @id @default(autoincrement())
  userId         BigInt    @map("user_id")
  artistId       BigInt    @map("artist_id")
  instagramUrl   String?   @map("instagram_url")
  reason         String
  status         String    @default("pending")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  decidedAt      DateTime? @map("decided_at") @db.Timestamptz(6)
  decidedBy      BigInt?   @map("decided_by")
  user           User      @relation("artist_claim_user", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  artist         Artist    @relation("artist_claim_artist", fields: [artistId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  decidedByUser  User?     @relation("artist_claim_decided_by", fields: [decidedBy], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([userId, status])
  @@index([artistId, status])
  @@map("artist_claims")
}

model User {
  id                  BigInt            @id @default(autoincrement())
  username            String            @unique
  email               String            @unique
  passwordHash        String            @map("password_hash")
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  role                String            @default("artist")
  status              String            @default("pending")
  artistId            BigInt?           @map("artist_id")
  mustChangePassword  Boolean           @default(false) @map("must_change_password")
  artist              Artist?           @relation(fields: [artistId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  artistClaims        ArtistClaim[]     @relation("artist_claim_user")
  decidedArtistClaims ArtistClaim[]     @relation("artist_claim_decided_by")
  recommendationJobs  RecommendationJob[]

  @@map("users")
}

model RecommendationJob {
  id           String    @id @db.Uuid
  userId       BigInt    @map("user_id")
  artistId     BigInt    @map("artist_id")
  jobType      String    @default("artist_promoters") @map("job_type")
  paramsHash   String    @map("params_hash")
  paramsJson   Json      @map("params_json")
  status       String    @default("queued")
  resultJson   Json?     @map("result_json")
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  startedAt    DateTime? @map("started_at") @db.Timestamptz(6)
  finishedAt   DateTime? @map("finished_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  artist       Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@map("recommendation_jobs")
}

model ImportRun {
  id               BigInt    @id @default(autoincrement())
  pipelineName     String    @default("full-pipeline") @map("pipeline_name")
  status           String    @default("running")
  minDate          DateTime? @map("min_date") @db.Date
  maxDate          DateTime? @map("max_date") @db.Date
  eventsJson       String?   @map("events_json")
  importJson       String?   @map("import_json")
  eventIdsFile     String?   @map("event_ids_file")
  artistIdsFile    String?   @map("artist_ids_file")
  eventCount       Int       @default(0) @map("event_count")
  artistCount      Int       @default(0) @map("artist_count")
  eventsImported   Int       @default(0) @map("events_imported")
  artistsImported  Int       @default(0) @map("artists_imported")
  eventPayloads    Int       @default(0) @map("event_payloads")
  eventTags        Int       @default(0) @map("event_tags")
  artistTags       Int       @default(0) @map("artist_tags")
  eventEmbeddings  Int       @default(0) @map("event_embeddings")
  artistEmbeddings Int       @default(0) @map("artist_embeddings")
  metadata         Json      @default("{}")
  error            String?
  startedAt        DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt       DateTime? @map("finished_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  stages           ImportRunStage[]

  @@index([startedAt])
  @@index([status, startedAt])
  @@map("import_runs")
}

model ImportRunStage {
  id          BigInt    @id @default(autoincrement())
  importRunId BigInt    @map("import_run_id")
  stageName   String    @map("stage_name")
  status      String    @default("running")
  command     String?
  durationMs  Int?      @map("duration_ms")
  metadata    Json      @default("{}")
  error       String?
  startedAt   DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt  DateTime? @map("finished_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  importRun   ImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([importRunId, stageName])
  @@map("import_run_stages")
}
