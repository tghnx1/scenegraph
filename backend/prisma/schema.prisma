generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
  enable_experimental_decimal = true
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id                BigInt   @id @default(autoincrement())
  ra_event_id       String   @unique
  title             String
  description_text  String?  @db.Text
  lineup_raw        String?  @db.Text
  content_url       String?
  event_date        DateTime? @db.Timestamptz(6)
  start_time        DateTime? @db.Timestamptz(6)
  end_time          DateTime? @db.Timestamptz(6)
  minimum_age       Int?
  cost_text         String?  @db.Text
  interested_count  Int?
  is_ticketed       Boolean?
  is_festival       Boolean?
  live              Boolean?
  has_secret_venue  Boolean?
  date_posted       DateTime? @db.Timestamptz(6)
  date_updated      DateTime? @db.Timestamptz(6)
  venue_id          BigInt?

  venue             Venue?               @relation(fields: [venue_id], references: [id])
  artists           EventArtist[]
  promoters         EventPromoter[]
  genres            EventGenre[]
  images            EventImage[]
  source_payload    EventSourcePayload?

  @@map("events")
}

model Venue {
  id           BigInt   @id @default(autoincrement())
  ra_venue_id  String   @unique
  name         String
  content_url  String?
  address      String?  @db.Text
  latitude     Decimal?
  longitude    Decimal?
  live         Boolean?
  area_name    String?
  country_code String?

  events       Event[]

  @@map("venues")
}

model Artist {
  id               BigInt   @id @default(autoincrement())
  ra_artist_id     String   @unique
  name             String
  content_url      String?
  url_safe_name    String?
  biography        String?  @db.Text
  biography_url    String?
  biography_status String?

  events           EventArtist[]

  @@map("artists")
}

model Promoter {
  id                BigInt   @id @default(autoincrement())
  ra_promoter_id    String   @unique
  name              String
  content_url       String?
  live              Boolean?
  has_ticket_access Boolean?

  events            EventPromoter[]

  @@map("promoters")
}

model Genre {
  id           BigInt   @id @default(autoincrement())
  ra_genre_id  String   @unique
  name         String
  slug         String?

  events       EventGenre[]

  @@map("genres")
}

model EventArtist {
  event_id  BigInt
  artist_id BigInt

  event     Event  @relation(fields: [event_id], references: [id])
  artist    Artist @relation(fields: [artist_id], references: [id])

  @@id([event_id, artist_id])
  @@map("event_artists")
}

model EventPromoter {
  event_id    BigInt
  promoter_id BigInt

  event       Event    @relation(fields: [event_id], references: [id])
  promoter    Promoter @relation(fields: [promoter_id], references: [id])

  @@id([event_id, promoter_id])
  @@map("event_promoters")
}

model EventGenre {
  event_id BigInt
  genre_id BigInt

  event    Event @relation(fields: [event_id], references: [id])
  genre    Genre @relation(fields: [genre_id], references: [id])

  @@id([event_id, genre_id])
  @@map("event_genres")
}

model EventImage {
  id          BigInt @id @default(autoincrement())
  ra_image_id String? @unique
  event_id    BigInt
  image_url   String
  image_type  String?
  alt_text    String?

  event       Event @relation(fields: [event_id], references: [id])

  @@map("event_images")
}

model EventSourcePayload {
  id              BigInt   @id @default(autoincrement())
  event_id        BigInt   @unique
  source_name     String   @default("ra")
  source_event_id String
  payload         Json
  fetched_at      DateTime @default(now()) @db.Timestamptz(6)

  event           Event @relation(fields: [event_id], references: [id])

  @@map("event_source_payloads")
}
