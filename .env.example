POSTGRES_DB=scenegraph
POSTGRES_USER=scenegraph
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443
RECOMMENDATION_WORKER=1
DATABASE_POOL_MIN_SIZE=1
DATABASE_POOL_MAX_SIZE=5
DATABASE_POOL_ACQUIRE_WARN_SECONDS=0.5
DATABASE_CONNECTION_HOLD_WARN_SECONDS=2.0
FULL_PIPELINE_ARTIFACTS_DIR=backend/data/import_runs
# Optional legacy override. If empty, full-pipeline writes per-run artifacts under FULL_PIPELINE_ARTIFACTS_DIR.
#DATABASE_URL=postgresql://scenegraph:change-me@db:5432/scenegraph
DATABASE_URL=postgresql://scenegraph_app:<PASSWORD>@scenegraph.cpokossgk60u.eu-north-1.rds.amazonaws.com:5432/scenegraph?sslmode=require

# Local Docker Postgres:
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=
OPENAI_EXTRACTION_MODEL=gpt-4.1-mini
EXTRACTION_PROVIDER=openai
EXTRACTION_API=
ARTIST_TAG_EXTRACTION_MAX_BIO_CHARS=6000
ARTIST_TAG_EXTRACTION_MAX_TAGS=32
EVENT_TAG_EXTRACTION_MAX_TEXT_CHARS=7000
EVENT_TAG_EXTRACTION_MAX_TAGS=28
EVENT_TAG_EXTRACTION_CHUNK_CHARS=800
RECOMMENDATION_JOB_RUNNING_RECLAIM_AFTER_SECONDS=600
# Promoter recommendation tuning lives in backend/app/recommendation_config.yaml.
ADMIN_METRICS_CACHE_TTL_SECONDS=15
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_CHAT_API_VERSION=2025-01-01-preview
AZURE_OPENAI_RESPONSES_URL=
AZURE_OPENAI_RESPONSES_MODEL=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_EXTRACTION_DEPLOYMENT=
VITE_API_URL=
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_UPDATE_EXISTING=false
BOOTSTRAP_USER_USERNAME=
BOOTSTRAP_USER_EMAIL=
BOOTSTRAP_USER_PASSWORD=
BOOTSTRAP_USER_ROLE=artist
BOOTSTRAP_USER_UPDATE_EXISTING=false
